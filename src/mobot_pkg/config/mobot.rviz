Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Status1
        - /TF1
        - /TF1/Frames1
        - /RobotModel1/Links1
        - /RobotModel1/Links1/base_link1
        - /RobotModel1/Links1/battery_link1
        - /RobotModel1/Links1/camera1_link1
        - /RobotModel1/Links1/jetson_link1
        - /RobotModel1/Links1/lidar1_link1
        - /RobotModel1/Links1/wheel_lb_link1
        - /RobotModel1/Links1/wheel_lf_link1
        - /RobotModel1/Links1/wheel_rb_link1
        - /RobotModel1/Links1/wheel_rf_link1
        - /Image1
      Splitter Ratio: 0.5470588207244873
    Tree Height: 802
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: LaserScan
  - Class: slam_toolbox::SlamToolboxPlugin
    Name: SlamToolboxPlugin
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
